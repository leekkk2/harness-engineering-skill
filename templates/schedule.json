{
  "$schema": "harness-schedule/v1",
  "description": "Entropy management scheduled task configuration",
  "schedules": [
    {
      "task": "drift-detector",
      "script": ".harness/entropy/drift-detector.sh",
      "frequency": "weekly",
      "day": "monday",
      "description": "Comprehensive architecture drift detection"
    },
    {
      "task": "doc-consistency",
      "script": ".harness/entropy/doc-consistency.sh",
      "frequency": "on-change",
      "trigger": "docs/**",
      "description": "Documentation-code consistency check"
    },
    {
      "task": "dependency-audit",
      "script": ".harness/entropy/dependency-audit.sh",
      "frequency": "weekly",
      "day": "friday",
      "description": "Dependency security and update audit"
    },
    {
      "task": "dead-code-scanner",
      "script": ".harness/entropy/dead-code-scanner.sh",
      "frequency": "monthly",
      "day": 1,
      "description": "Dead code detection"
    },
    {
      "task": "harness-health",
      "script": ".harness/entropy/harness-health.sh",
      "frequency": "daily",
      "description": "Harness self-health check"
    }
  ]
}
