{
  "$schema": "sprint-contract/v1",
  "id": "sprint-YYYY-MM-DD-NNN",
  "created": "YYYY-MM-DDTHH:MM:SSZ",
  "status": "draft",
  "objective": "One-line description of this Sprint's goal",
  "scope": {
    "modules": [
      "src/modules/target-module"
    ],
    "read_only": [
      "src/config",
      "src/types"
    ],
    "forbidden": [
      "other-submodule/**"
    ]
  },
  "success_criteria": [
    {
      "id": "SC-1",
      "description": "Describe the expected behavior or output",
      "verification": "How to verify (e.g., curl command, test command, JSON schema validation)",
      "status": "pending"
    },
    {
      "id": "SC-2",
      "description": "Second acceptance criterion",
      "verification": "Verification method",
      "status": "pending"
    }
  ],
  "constraints": [
    "Do not modify existing API interface signatures",
    "Use existing middleware patterns",
    "Error handling follows project-wide conventions"
  ],
  "agents": {
    "generator": {
      "model": "claude-opus-4-6",
      "context": ".harness/context/server.md",
      "role": "Implement feature code"
    },
    "evaluator": {
      "model": "claude-sonnet-4-6",
      "context": ".harness/sensors/eval/criteria/",
      "role": "Evaluate code quality and acceptance criteria"
    }
  },
  "timeline": {
    "estimated_duration": "2h",
    "max_iterations": 3
  },
  "notes": ""
}
